[package]
name = "{{ project_name }}"
version = "0.1.0"
edition = "2024"
description = "Minimal Axum starter template"
license = "MIT"

[dependencies]
axum = "0.8.8"
dotenvy = "0.15.7"
serde = { version = "1.0.228", features = ["derive"] }
tokio = { version = "1.51.0", features = ["macros", "net", "rt-multi-thread"] }
tower-http = { version = "0.6.8", features = ["cors"] }
